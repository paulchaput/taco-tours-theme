<section class="tt-guide tt-section full-width" id="guide">
  <div class="tt-container">
    <div class="tt-guide__inner">
      <div class="tt-guide__image">
        {% if section.settings.guide_image %}
          {{ section.settings.guide_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.name }}
        {% else %}
          <div style="width:100%;height:100%;background:var(--color-border);display:flex;align-items:center;justify-content:center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-text-muted);opacity:0.3;"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
        {% endif %}
      </div>

      <div class="tt-guide__text">
        <p class="tt-section-label">{{ section.settings.label | default: 'Meet your guide' }}</p>
        <h2 class="tt-guide__name">{{ section.settings.name | default: 'Christopher Chaput' }}</h2>
        <p class="tt-guide__handle">{{ section.settings.handle | default: '@elperritotaquero' }}</p>
        <p class="tt-guide__bio">{{ section.settings.bio | default: "Born in Canada, raised on Mexican street food. Christopher has spent years exploring every colonia in CDMX to find the tacos that tell a story. With a growing community of taco lovers on social media, he now shares his favorites in person — one tour at a time." }}</p>

        <div class="tt-guide__social">
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="tt-guide__social-link" target="_blank" rel="noopener" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.37-6.22V9.52a8.3 8.3 0 0 0 3.85.92V7a4.85 4.85 0 0 1-0-.31z"/></svg>
              TikTok
            </a>
          {% endif %}
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="tt-guide__social-link" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              Instagram
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Meet Your Guide",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Meet your guide"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Guide name",
      "default": "Christopher Chaput"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Social handle",
      "default": "@elperritotaquero"
    },
    {
      "type": "textarea",
      "id": "bio",
      "label": "Bio",
      "default": "Born in Canada, raised on Mexican street food. Christopher has spent years exploring every colonia in CDMX to find the tacos that tell a story. With a growing community of taco lovers on social media, he now shares his favorites in person — one tour at a time."
    },
    {
      "type": "image_picker",
      "id": "guide_image",
      "label": "Guide photo"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    {
      "name": "Meet Your Guide"
    }
  ]
}
{% endschema %}
