<section class="tt-hero full-width">
  <div class="tt-hero__media">
    {% if section.settings.video_url != blank %}
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.hero_image %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: loading: 'eager' }}
    {% endif %}
  </div>
  <div class="tt-hero__overlay"></div>

  <div class="tt-hero__content">
    <p class="tt-hero__label">{{ section.settings.label | default: 'Mexico City Taco Experience' }}</p>
    <h1 class="tt-hero__title">{{ section.settings.title | default: 'Explore Mexico City through <em>tacos</em>' }}</h1>
    <p class="tt-hero__description">{{ section.settings.description | default: 'Join our curated taco tour through the best taquerias of CDMX. 4 stops, 8 tacos, one unforgettable experience.' }}</p>

    <div class="tt-hero__actions">
      <a href="{{ section.settings.cta_url | default: '#book' }}" class="tt-btn tt-btn--primary tt-btn--large">
        {{ section.settings.cta_text | default: 'Book Your Tour' }}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <div class="tt-hero__price">
        From <strong>${{ section.settings.price | default: '1,500' }} MXN</strong> per person
      </div>
    </div>

    <div class="tt-hero__stats">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <div class="tt-hero__stat-value">{{ block.settings.value }}</div>
          <div class="tt-hero__stat-label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Taco Hero",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Mexico City Taco Experience"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Explore Mexico City through <em>tacos</em></p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Join our curated taco tour through the best taquerias of CDMX. 4 stops, 8 tacos, one unforgettable experience."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (mp4)"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Book Your Tour"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price display",
      "default": "1,500"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "4"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Taquerias"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Taco Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "4", "label": "Taquerias" } },
        { "type": "stat", "settings": { "value": "8", "label": "Tacos" } },
        { "type": "stat", "settings": { "value": "3-4h", "label": "Duration" } },
        { "type": "stat", "settings": { "value": "10", "label": "Max Group" } }
      ]
    }
  ]
}
{% endschema %}
